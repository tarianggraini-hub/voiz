# ─────────────────────────────────────────
#  VOIZ — Konfigurasi Environment
#  Simpan file ini sebagai .env di folder backend/
# ─────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# Database MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=voiz_db

# JWT
JWT_SECRET=voiz_secret_key_ganti_ini_123!
JWT_EXPIRES_IN=7d

# Frontend (untuk CORS) — sesuaikan port Live Server kamu
CLIENT_URL=http://127.0.0.1:5500